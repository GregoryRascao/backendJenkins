{
   "name": "BalrogBackend",
   "version": "0.0.1",
   "description": "Awesome project developed with TypeORM.",
   "type": "commonjs",
   "devDependencies": {
      "@types/bcrypt": "^5.0.0",
      "@types/cors": "^2.8.12",
      "@types/jest": "^30.0.0",
      "@types/jsonwebtoken": "^8.5.8",
      "@types/node": "^16.11.10",
      "@types/supertest": "^7.2.0",
      "jest": "^30.2.0",
      "jsonwebtoken": "^8.5.1",
      "nodemon": "^2.0.19",
      "supertest": "^7.2.2",
      "ts-jest": "^29.4.6",
      "ts-node": "10.7.0",
      "typescript": "4.5.2"
   },
   "dependencies": {
      "bcrypt": "^5.0.1",
      "body-parser": "^1.19.1",
      "cors": "^2.8.5",
      "dotenv": "^17.3.1",
      "express": "^4.17.2",
      "mysql": "^2.14.1",
      "pg": "^8.7.3",
      "reflect-metadata": "^0.1.13",
      "sqlite3": "^5.1.7",
      "typeorm": "0.3.7"
   },
   "scripts": {
      "start": "ts-node src/index.ts",
      "typeorm": "typeorm-ts-node-commonjs",
      "debug": "nodemon --inspect src/index.ts",
      "migration:create": "npm run typeorm -- migration:generate -d src/data-source.ts",
      "migrate": "npm run typeorm -- migration:run -d src/data-source.ts",
      "test": "jest",
      "test:watch": "jest --watchAll"
   }
}
